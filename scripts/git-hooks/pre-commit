#!/bin/bash
# Git pre-commit hook - Normaliza finales de línea automáticamente
# Este hook previene errores de CRLF en GitHub Classroom autograding

echo "🔍 Pre-commit: Verificando finales de línea..."

# Obtener archivos staged que son de texto
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(php|sh|bash|puml|json|yml|yaml|md|txt|xml|ini)$' || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "📝 Normalizando $(echo "$STAGED_FILES" | wc -l) archivo(s)..."

# Normalizar cada archivo staged
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        # Convertir CRLF a LF
        sed -i 's/\r$//' "$FILE" 2>/dev/null || true
        
        # Re-agregar al stage después de normalizar
        git add "$FILE"
    fi
done

echo "✅ Finales de línea normalizados a LF (Unix)"
exit 0
