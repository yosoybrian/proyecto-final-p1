# .gitattributes - Normalización de finales de línea para evitar errores en autograding

# Por defecto, todos los archivos de texto usan LF (Unix)
# Esto previene el error: /usr/bin/env: 'php\r': No such file or directory
* text=auto eol=lf

# Archivos de código fuente
*.php text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.puml text eol=lf
*.plantuml text eol=lf

# Archivos de documentación
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf

# Archivos de configuración
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
composer.json text eol=lf
composer.lock text eol=lf
package.json text eol=lf

# Archivos de proyecto
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Scripts ejecutables DEBEN usar LF
*.sh text eol=lf
generar-*.sh text eol=lf
setup-*.sh text eol=lf
fix-*.sh text eol=lf
scripts/*.sh text eol=lf

# Archivos binarios (no convertir)
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
