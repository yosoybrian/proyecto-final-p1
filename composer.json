{
    "name": "php-exercises/testing-environment",
    "description": "Entorno de desarrollo para ejercicios PHP con tests automáticos",
    "type": "project",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Exercises\\": "exercises/",
            "CitasMedicas\\": "src/",
            "App\\": "src/",
            "ApiEjercicio\\": "exercises/api-ejercicio/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php -d xdebug.mode=off vendor/bin/phpunit",
        "test-watch": "php -d xdebug.mode=off vendor/bin/phpunit --testdox",
        "test:ejercicio1": "php -d xdebug.mode=off vendor/bin/phpunit --group ejercicio1 --no-coverage --testdox",
        "test:ejercicio2": "php -d xdebug.mode=off vendor/bin/phpunit --group ejercicio2 --no-coverage --testdox",
        "test:ejercicio3": "php -d xdebug.mode=off vendor/bin/phpunit --group ejercicio3 --no-coverage --testdox",
        "test:ejercicios": "php -d xdebug.mode=off vendor/bin/phpunit --group ejercicio1,ejercicio2,ejercicio3 --no-coverage --testdox",
        "test:api": "php -d xdebug.mode=off vendor/bin/phpunit --group api --no-coverage --testdox",
        "test:api-http": "php -d xdebug.mode=off vendor/bin/phpunit --group http --no-coverage --testdox",
        "analyze": "php vendor/bin/phpstan analyse exercises --level=8",
        "style-check": "php vendor/bin/phpcs exercises --standard=PSR12",
        "style-fix": "php vendor/bin/phpcbf exercises --standard=PSR12",
        "serve": "php -S 0.0.0.0:8000 -t public",
        "serve:api": "php -S localhost:8000 -t exercises/api-ejercicio/public exercises/api-ejercicio/router.php",
        "autograding": "@php -r \"exec('./scripts/secure-grading-report.sh 2>&1', \\$output, \\$return); echo implode(PHP_EOL, \\$output);\"",
        "fix-line-endings": "@php -r \"exec('find vendor/bin -type f -exec sed -i \\'s/\\r$/\\' {} \\; 2>/dev/null || true');\"",
        "post-install-cmd": "@fix-line-endings",
        "post-update-cmd": "@fix-line-endings"
    },
    "config": {
        "process-timeout": 1200
    }
}
